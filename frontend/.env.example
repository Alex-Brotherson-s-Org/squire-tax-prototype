# Frontend environment template. Safe to commit — contains no real secrets.
# To set up:
#   1. Copy this file to frontend/.env
#   2. Replace the placeholder values with real keys from your Supabase
#      project (Project Settings -> API)
#
# Vite only exposes variables prefixed with VITE_ to client-side code.
# Do NOT add the service-role/secret key here — it would ship to every
# user's browser.
#
# VITE_SUPABASE_URL      Public project URL.
# VITE_SUPABASE_ANON_KEY Anon (or "publishable") public key. Safe to expose
#                        to the browser — it relies on row-level security
#                        for actual access control.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here
